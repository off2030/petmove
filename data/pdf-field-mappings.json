      "rabies2_serial":       { "source": "rabies_dates", "transform": "vaccine:rabies:serial[1]" },
      "rabies2_vacc_date":    { "source": "rabies_dates", "transform": "vaccine:rabies:date[1]" },
      "rabies2_validity_1Y":  { "source": "rabies_dates", "transform": "has[1]" },
      "rabies3_product":      { "source": "rabies_dates", "transform": "vaccine:rabies:name[2]" },
      "rabies3_manufacturer": { "source": "rabies_dates", "transform": "vaccine:rabies:manufacturer[2]" },
      "rabies3_serial":       { "source": "rabies_dates", "transform": "vaccine:rabies:serial[2]" },
      "rabies3_vacc_date":    { "source": "rabies_dates", "transform": "vaccine:rabies:date[2]" },
      "rabies3_validity_1Y":  { "source": "rabies_dates", "transform": "has[2]" },
      "other1_product_type":  { "source": null, "transform": "other_vacc_seq:type[0]", "note": "종합백신→외부→내부 순서로 최신 1건씩, 없는 타입 skip" },
      "other1_product_name":  { "source": null, "transform": "other_vacc_seq:name[0]" },
      "other1_manufacturer":  { "source": null, "transform": "other_vacc_seq:manufacturer[0]" },
      "other1_serial":        { "source": null, "transform": "other_vacc_seq:serial[0]" },
      "other1_date":          { "source": null, "transform": "other_vacc_seq:date[0]" },
      "other2_product_type":  { "source": null, "transform": "other_vacc_seq:type[1]" },
      "other2_product_name":  { "source": null, "transform": "other_vacc_seq:name[1]" },
      "other2_manufacturer":  { "source": null, "transform": "other_vacc_seq:manufacturer[1]" },
      "other2_serial":        { "source": null, "transform": "other_vacc_seq:serial[1]" },
      "other2_date":          { "source": null, "transform": "other_vacc_seq:date[1]" },
      "other3_product_type":  { "source": null, "transform": "other_vacc_seq:type[2]" },
      "other3_product_name":  { "source": null, "transform": "other_vacc_seq:name[2]" },
      "other3_manufacturer":  { "source": null, "transform": "other_vacc_seq:manufacturer[2]" },
      "other3_serial":        { "source": null, "transform": "other_vacc_seq:serial[2]" },
      "other3_date":          { "source": null, "transform": "other_vacc_seq:date[2]" },
      "clinical_cert_kr":     { "source": null, "transform": "checkbox:always_true" },
      "clinical_cert_en":     { "source": null, "transform": "checkbox:always_true" },
      "hospital_name":        { "source": null, "default": "Lausanne Veterinary Medical Center" },
      "hospital_phone":       { "source": null, "default": "+82-2-872-7588" },
      "hospital_address1":    { "source": null, "default": "3, Gwanak-ro 29-gil", "note": "1=거리 주소" },
      "hospital_address2":    { "source": null, "default": "Gwanak-gu, Seoul, Republic of Korea", "note": "2=시/지역/국가" },
      "hospital_address3":    { "source": null },
