{
  "FormRE": {
    "template": "FormRE.pdf",
    "description": "Japan re-entry certificate (from non-designated region)",
    "filename": "FormRE_{pet_name}.pdf",
    "fields": {
      "consignor_name":       { "source": "customer_name_en" },
      "consignor_address":    { "source": "address_en" },
      "consignee_name":       { "source": "customer_name_en" },
      "consignee_address":    { "source": "address_overseas" },
      "species":              { "source": "species", "transform": "en" },
      "breed":                { "source": "breed_en" },
      "pet_name":             { "source": "pet_name_en" },
      "sex_male":             { "source": "sex", "transform": "checkbox:in:male|neutered_male" },
      "sex_female":           { "source": "sex", "transform": "checkbox:in:female|spayed_female" },
      "birth_or_age":         { "source": "birth_date", "transform": "date_or_age" },
      "color":                { "source": "color_en" },
      "use_pet":              { "source": null, "transform": "checkbox:always_true" },
      "microchip":            { "source": "microchip" },
      "id_date":              { "source": "microchip_implant_date" },
      "rabies_cert_number":   { "source": null, "note": "일본 AQS 수출검역증명서 번호 — 케이스 데이터 없음" },
      "rabies_date_1":        { "source": "rabies_dates", "transform": "after_titer[0]", "note": "1차 항체검사일 이후 추가접종분만" },
      "rabies_date_2":        { "source": "rabies_dates", "transform": "after_titer[1]" },
      "rabies_period_1":      { "source": "rabies_dates", "transform": "after_titer_period[0]" },
      "rabies_period_2":      { "source": "rabies_dates", "transform": "after_titer_period[1]" },
      "rabies_product_1":     { "source": "rabies_dates", "transform": "after_titer_product[0]" },
      "rabies_product_2":     { "source": "rabies_dates", "transform": "after_titer_product[1]" },
      "titer_cert_number":    { "source": null, "note": "일본 AQS 항체가검사 증명서 번호" },
      "titer_date_1":         { "source": "rabies_titer_records", "transform": "if_multi[0].date", "note": "2차 항체검사(최신)가 있을 때만 출력" },
      "titer_value_1":        { "source": "rabies_titer_records", "transform": "if_multi[0].value" },
      "titer_lab_name_1":     { "source": "rabies_titer_records", "transform": "if_multi[0].lab" },
      "titer_lab_country_1":  { "source": "rabies_titer_records", "transform": "if_multi[0].lab_country" },
      "vet_name":             { "source": null, "default": "Jinwon Lee" },
      "vet_address":          { "source": null, "default": "3, Gwanak-ro 29-gil, Gwanak-gu, Seoul, Republic of Korea" },
      "inspection_date":      { "source": "vet_visit_date" }
    }
  },
  "IdentificationDeclaration": {
    "template": "IdentificationDeclaration.pdf",
    "description": "Australia identification declaration (10-day PEQ eligibility)",
    "filename": "IdentificationDeclaration_{pet_name}.pdf",
    "fields": {
      "animal_name":          { "source": "pet_name_en" },
      "birth_date":           { "source": "birth_date", "transform": "date_dmy" },
      "breed_desc":           { "source": "breed_en" },
      "sex_male_entire":      { "source": "sex", "transform": "checkbox:eq:male" },
      "sex_neutered_male":    { "source": "sex", "transform": "checkbox:eq:neutered_male" },
      "sex_female_entire":    { "source": "sex", "transform": "checkbox:eq:female" },
      "sex_neutered_female":  { "source": "sex", "transform": "checkbox:eq:spayed_female" },
      "importer_name":        { "source": "customer_name_en" },
      "animal_name_b":        { "source": "pet_name_en" },
      "birth_date_b":         { "source": "birth_date", "transform": "date_dmy" },
      "sex_b_male":           { "source": "sex", "transform": "checkbox:eq:male" },
      "sex_b_neutered_male":  { "source": "sex", "transform": "checkbox:eq:neutered_male" },
      "sex_b_female":         { "source": "sex", "transform": "checkbox:eq:female" },
      "sex_b_neutered_female":{ "source": "sex", "transform": "checkbox:eq:spayed_female" },
      "description_b":        { "source": "breed_en" },
      "microchip_site":       { "source": null, "note": "수의사 기입 — 케이스 데이터 없음" },
      "chip1_01": { "source": "microchip", "transform": "digit[0]" },
      "chip1_02": { "source": "microchip", "transform": "digit[1]" },
      "chip1_03": { "source": "microchip", "transform": "digit[2]" },
      "chip1_04": { "source": "microchip", "transform": "digit[3]" },
      "chip1_05": { "source": "microchip", "transform": "digit[4]" },
      "chip1_06": { "source": "microchip", "transform": "digit[5]" },
      "chip1_07": { "source": "microchip", "transform": "digit[6]" },
      "chip1_08": { "source": "microchip", "transform": "digit[7]" },
      "chip1_09": { "source": "microchip", "transform": "digit[8]" },
      "chip1_10": { "source": "microchip", "transform": "digit[9]" },
      "chip1_11": { "source": "microchip", "transform": "digit[10]" },
      "chip1_12": { "source": "microchip", "transform": "digit[11]" },
      "chip1_13": { "source": "microchip", "transform": "digit[12]" },
      "chip1_14": { "source": "microchip", "transform": "digit[13]" },
      "chip1_15": { "source": "microchip", "transform": "digit[14]" },
      "chip2_01": { "source": null, "note": "2차 마이크로칩 — 케이스 데이터 없음" },
      "chip2_02": { "source": null },
      "chip2_03": { "source": null },
      "chip2_04": { "source": null },
      "chip2_05": { "source": null },
      "chip2_06": { "source": null },
      "chip2_07": { "source": null },
      "chip2_08": { "source": null },
      "chip2_09": { "source": null },
      "chip2_10": { "source": null },
      "chip2_11": { "source": null },
      "chip2_12": { "source": null },
      "chip2_13": { "source": null },
      "chip2_14": { "source": null },
      "chip2_15": { "source": null }
    }
  },
  "Form25": {
    "template": "Form25.pdf",
    "description": "별지 제25호서식 — 예방접종 및 건강증명서",
    "filename": "Form25_{pet_name}.pdf",
    "fields": {
      "owner_name":           { "source": "customer_name_en" },
      "owner_phone":          { "source": "phone", "transform": "phone_dash" },
      "owner_address":        { "source": "address_en" },
      "species_dog":          { "source": "species", "transform": "checkbox:eq:dog" },
      "species_cat":          { "source": "species", "transform": "checkbox:eq:cat" },
      "species_other":        { "source": null, "note": "견/묘 외 — 수기 기입" },
      "species_other_text":   { "source": null },
      "sex_male":             { "source": "sex", "transform": "checkbox:eq:male" },
      "sex_female":           { "source": "sex", "transform": "checkbox:eq:female" },
      "sex_neutered_male":    { "source": "sex", "transform": "checkbox:eq:neutered_male" },
      "sex_neutered_female":  { "source": "sex", "transform": "checkbox:eq:spayed_female" },
      "age_years":            { "source": "birth_date", "transform": "age_years" },
      "age_months":           { "source": "birth_date", "transform": "age_months" },
      "birth_date":           { "source": "birth_date" },
      "color_marks":          { "source": "color_en" },
      "breed":                { "source": "breed_en" },
      "pet_name":             { "source": "pet_name_en" },
      "weight_under_5kg":     { "source": "weight", "transform": "cmp:num:le:5" },
      "weight_5_to_10kg":     { "source": "weight", "transform": "cmp:num:gt_lt:5:10" },
      "weight_over_10kg":     { "source": "weight", "transform": "cmp:num:ge:10" },
      "weight_kg":            { "source": "weight" },
      "microchip_yes":        { "source": "microchip", "transform": "checkbox:truthy" },
      "microchip_no":         { "source": "microchip", "transform": "checkbox:falsy" },
      "microchip_number":     { "source": "microchip" },
      "microchip_implant_date":{ "source": "microchip_implant_date" },
      "rabies1_product":      { "source": "rabies_dates", "transform": "vaccine:rabies:name[0]" },
      "rabies1_manufacturer": { "source": "rabies_dates", "transform": "vaccine:rabies:manufacturer[0]" },
      "rabies1_serial":       { "source": "rabies_dates", "transform": "vaccine:rabies:serial[0]" },
      "rabies1_vacc_date":    { "source": "rabies_dates", "transform": "vaccine:rabies:date[0]" },
      "rabies1_validity_1Y":  { "source": "rabies_dates", "transform": "has[0]" },
      "rabies2_product":      { "source": "rabies_dates", "transform": "vaccine:rabies:name[1]" },
      "rabies2_manufacturer": { "source": "rabies_dates", "transform": "vaccine:rabies:manufacturer[1]" },
      "rabies2_serial":       { "source": "rabies_dates", "transform": "vaccine:rabies:serial[1]" },
      "rabies2_vacc_date":    { "source": "rabies_dates", "transform": "vaccine:rabies:date[1]" },
      "rabies2_validity_1Y":  { "source": "rabies_dates", "transform": "has[1]" },
      "rabies3_product":      { "source": "rabies_dates", "transform": "vaccine:rabies:name[2]" },
      "rabies3_manufacturer": { "source": "rabies_dates", "transform": "vaccine:rabies:manufacturer[2]" },
      "rabies3_serial":       { "source": "rabies_dates", "transform": "vaccine:rabies:serial[2]" },
      "rabies3_vacc_date":    { "source": "rabies_dates", "transform": "vaccine:rabies:date[2]" },
      "rabies3_validity_1Y":  { "source": "rabies_dates", "transform": "has[2]" },
      "other1_product_type":  { "source": null, "transform": "other_vacc_seq:type[0]", "note": "종합백신→외부→내부 순서로 최신 1건씩, 없는 타입 skip" },
      "other1_product_name":  { "source": null, "transform": "other_vacc_seq:name[0]" },
      "other1_manufacturer":  { "source": null, "transform": "other_vacc_seq:manufacturer[0]" },
      "other1_serial":        { "source": null, "transform": "other_vacc_seq:serial[0]" },
      "other1_date":          { "source": null, "transform": "other_vacc_seq:date[0]" },
      "other2_product_type":  { "source": null, "transform": "other_vacc_seq:type[1]" },
      "other2_product_name":  { "source": null, "transform": "other_vacc_seq:name[1]" },
      "other2_manufacturer":  { "source": null, "transform": "other_vacc_seq:manufacturer[1]" },
      "other2_serial":        { "source": null, "transform": "other_vacc_seq:serial[1]" },
      "other2_date":          { "source": null, "transform": "other_vacc_seq:date[1]" },
      "other3_product_type":  { "source": null, "transform": "other_vacc_seq:type[2]" },
      "other3_product_name":  { "source": null, "transform": "other_vacc_seq:name[2]" },
      "other3_manufacturer":  { "source": null, "transform": "other_vacc_seq:manufacturer[2]" },
      "other3_serial":        { "source": null, "transform": "other_vacc_seq:serial[2]" },
      "other3_date":          { "source": null, "transform": "other_vacc_seq:date[2]" },
      "clinical_cert_kr":     { "source": null, "transform": "checkbox:always_true" },
      "clinical_cert_en":     { "source": null, "transform": "checkbox:always_true" },
      "hospital_name":        { "source": null, "default": "Lausanne Veterinary Medical Center" },
      "hospital_phone":       { "source": null, "default": "+82-2-872-7588" },
      "hospital_address1":    { "source": null, "default": "3, Gwanak-ro 29-gil, Gwanak-gu, Seoul, Republic of Korea" },
      "hospital_address2":    { "source": null },
      "hospital_address3":    { "source": null },
      "vet_license_number":   { "source": null, "default": "908" },
      "vet_name":             { "source": null, "default": "Jinwon Lee" },
      "vet_signature":        { "source": null, "note": "수의사 서명 — 수기" },
      "issue_date":           { "source": null, "transform": "today_ymd_slash" }
    }
  }
}
