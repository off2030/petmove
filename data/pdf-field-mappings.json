{
  "FormRE": {
    "template": "FormRE.pdf",
    "description": "Japan re-entry certificate (from non-designated region)",
    "filename": "FormRE_{pet_name}.pdf",
    "fields": {
      "consignor_name":       { "source": "customer_name_en" },
      "consignor_address":    { "source": "address_en" },
      "consignee_name":       { "source": "customer_name_en" },
      "consignee_address":    { "source": "address_overseas" },
      "species":              { "source": "species", "transform": "en" },
      "breed":                { "source": "breed_en" },
      "pet_name":             { "source": "pet_name_en" },
      "sex_male":             { "source": "sex", "transform": "checkbox:male" },
      "sex_female":           { "source": "sex", "transform": "checkbox:female" },
      "birth_or_age":         { "source": "birth_date", "transform": "date_or_age" },
      "color":                { "source": "color_en" },
      "use_pet":              { "source": null, "transform": "checkbox:always_true" },
      "microchip":            { "source": "microchip" },
      "id_date":              { "source": "microchip_implant_date" },
      "rabies_cert_number":   { "source": null, "note": "일본 AQS 수출검역증명서 번호 — 케이스 데이터 없음" },
      "rabies_date_1":        { "source": "rabies_dates", "transform": "after_titer[0]", "note": "1차 항체검사일 이후 추가접종분만" },
      "rabies_date_2":        { "source": "rabies_dates", "transform": "after_titer[1]" },
      "rabies_period_1":      { "source": "rabies_dates", "transform": "after_titer_period[0]" },
      "rabies_period_2":      { "source": "rabies_dates", "transform": "after_titer_period[1]" },
      "rabies_product_1":     { "source": "rabies_dates", "transform": "after_titer_product[0]" },
      "rabies_product_2":     { "source": "rabies_dates", "transform": "after_titer_product[1]" },
      "titer_cert_number":    { "source": null, "note": "일본 AQS 항체가검사 증명서 번호" },
      "titer_date_1":         { "source": "rabies_titer_records", "transform": "if_multi[0].date", "note": "2차 항체검사(최신)가 있을 때만 출력" },
      "titer_value_1":        { "source": "rabies_titer_records", "transform": "if_multi[0].value" },
      "titer_lab_name_1":     { "source": "rabies_titer_records", "transform": "if_multi[0].lab" },
      "titer_lab_country_1":  { "source": "rabies_titer_records", "transform": "if_multi[0].lab_country" },
      "vet_name":             { "source": null, "default": "Jinwon Lee" },
      "vet_address":          { "source": null, "default": "3, Gwanak-ro 29-gil, Gwanak-gu, Seoul, Republic of Korea" },
      "inspection_date":      { "source": "vet_visit_date" }
    }
  }
}
