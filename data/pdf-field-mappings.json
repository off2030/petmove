{
  "FormAC": {
    "template": "FormAC.pdf",
    "description": "Japan import certificate — Form AC (Certificate for dogs/cats/foxes/raccoons/skunks to be imported into Japan from NON-DESIGNATED REGION, 別記様式第4号の3)",
    "filename": "FormAC_{pet_name}.pdf",
    "fields": {
      "exporting_country":    { "source": null, "default": "Republic of Korea" },
      "consignor_name":       { "source": "customer_name_en" },
      "consignor_address":    { "source": "address_en" },
      "consignee_name":       { "source": "customer_name_en" },
      "species":              { "source": "species", "transform": "en" },
      "breed":                { "source": "breed_en" },
      "pet_name":             { "source": "pet_name_en" },
      "sex_male":             { "source": "sex", "transform": "checkbox:in:male|neutered_male" },
      "sex_female":           { "source": "sex", "transform": "checkbox:in:female|spayed_female" },
      "birth_or_age":         { "source": "birth_date", "transform": "date_or_age" },
      "color":                { "source": "color_en" },
      "use_pet":              { "source": null, "transform": "checkbox:always_true" },
      "microchip":            { "source": "microchip" },
      "id_date":              { "source": "microchip_implant_date" },
      "rabies1_date":         { "source": "rabies_dates", "transform": "array[0]", "note": "Row I = 최신 접종일" },
      "rabies1_period":       { "source": "rabies_dates", "transform": "period[0]" },
      "rabies1_product":      { "source": "rabies_dates", "transform": "product[0]" },
      "rabies2_date":         { "source": "rabies_dates", "transform": "array[1]" },
      "rabies2_period":       { "source": "rabies_dates", "transform": "period[1]" },
      "rabies2_product":      { "source": "rabies_dates", "transform": "product[1]" },
      "rabies3_date":         { "source": "rabies_dates", "transform": "array[2]" },
      "rabies3_period":       { "source": "rabies_dates", "transform": "period[2]" },
      "rabies3_product":      { "source": "rabies_dates", "transform": "product[2]" },
      "rabies4_date":         { "source": "rabies_dates", "transform": "array[3]" },
      "rabies4_period":       { "source": "rabies_dates", "transform": "period[3]" },
      "rabies4_product":      { "source": "rabies_dates", "transform": "product[3]" },
      "rabies5_date":         { "source": "rabies_dates", "transform": "array[4]" },
      "rabies5_period":       { "source": "rabies_dates", "transform": "period[4]" },
      "rabies5_product":      { "source": "rabies_dates", "transform": "product[4]" },
      "rabies6_date":         { "source": "rabies_dates", "transform": "array[5]" },
      "rabies6_period":       { "source": "rabies_dates", "transform": "period[5]" },
      "rabies6_product":      { "source": "rabies_dates", "transform": "product[5]" },
      "titer1_date":          { "source": "rabies_titer_records", "transform": "array[0].date", "note": "Row I = 최신 항체검사" },
      "titer1_value":         { "source": "rabies_titer_records", "transform": "array[0].value" },
      "titer1_lab_name":      { "source": "rabies_titer_records", "transform": "array[0].lab" },
      "titer1_lab_country":   { "source": "rabies_titer_records", "transform": "array[0].lab_country" },
      "titer2_date":          { "source": "rabies_titer_records", "transform": "array[1].date" },
      "titer2_value":         { "source": "rabies_titer_records", "transform": "array[1].value" },
      "titer2_lab_name":      { "source": "rabies_titer_records", "transform": "array[1].lab" },
      "titer2_lab_country":   { "source": "rabies_titer_records", "transform": "array[1].lab_country" },
      "vet_name":             { "source": null, "default": "Jinwon Lee" },
      "vet_address":          { "source": null, "default": "3, Gwanak-ro 29-gil, Gwanak-gu, Seoul, Republic of Korea" },
      "inspection_date":      { "source": "vet_visit_date" }
    }
  },
  "FormRE": {
    "template": "FormRE.pdf",
    "description": "Japan re-entry certificate (from non-designated region)",
    "filename": "FormRE_{pet_name}.pdf",
    "fields": {
      "consignor_name":       { "source": "customer_name_en" },
      "consignor_address":    { "source": "address_en" },
      "consignee_name":       { "source": "customer_name_en" },
      "consignee_address":    { "source": "address_overseas" },
      "species":              { "source": "species", "transform": "en" },
      "breed":                { "source": "breed_en" },
      "pet_name":             { "source": "pet_name_en" },
      "sex_male":             { "source": "sex", "transform": "checkbox:in:male|neutered_male" },
      "sex_female":           { "source": "sex", "transform": "checkbox:in:female|spayed_female" },
      "birth_or_age":         { "source": "birth_date", "transform": "date_or_age" },
      "color":                { "source": "color_en" },
      "use_pet":              { "source": null, "transform": "checkbox:always_true" },
      "microchip":            { "source": "microchip" },
      "id_date":              { "source": "microchip_implant_date" },
      "rabies_cert_number":   { "source": null, "note": "일본 AQS 수출검역증명서 번호 — 케이스 데이터 없음" },
      "rabies_date_1":        { "source": "rabies_dates", "transform": "after_titer[0]", "note": "1차 항체검사일 이후 추가접종분만" },
      "rabies_date_2":        { "source": "rabies_dates", "transform": "after_titer[1]" },
      "rabies_period_1":      { "source": "rabies_dates", "transform": "after_titer_period[0]" },
      "rabies_period_2":      { "source": "rabies_dates", "transform": "after_titer_period[1]" },
      "rabies_product_1":     { "source": "rabies_dates", "transform": "after_titer_product[0]" },
      "rabies_product_2":     { "source": "rabies_dates", "transform": "after_titer_product[1]" },
      "titer_cert_number":    { "source": null, "note": "일본 AQS 항체가검사 증명서 번호" },
      "titer_date_1":         { "source": "rabies_titer_records", "transform": "if_multi[0].date", "note": "2차 항체검사(최신)가 있을 때만 출력" },
      "titer_value_1":        { "source": "rabies_titer_records", "transform": "if_multi[0].value" },
      "titer_lab_name_1":     { "source": "rabies_titer_records", "transform": "if_multi[0].lab" },
      "titer_lab_country_1":  { "source": "rabies_titer_records", "transform": "if_multi[0].lab_country" },
      "vet_name":             { "source": null, "default": "Jinwon Lee" },
      "vet_address":          { "source": null, "default": "3, Gwanak-ro 29-gil, Gwanak-gu, Seoul, Republic of Korea" },
      "inspection_date":      { "source": "vet_visit_date" }
    }
  },
  "IdentificationDeclaration": {
