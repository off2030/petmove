# Copy this file to .env.local and fill in real values.
# .env.local is gitignored - never commit real keys.

# ─── Supabase (from https://supabase.com/dashboard) ───
# Project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://jxyalwbstsqpecavqfkb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Service role (server-only, never expose to browser)
# Used by import scripts and admin operations
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenAI (from https://platform.openai.com/api-keys) ───
# Used by lib/actions/extract-*.ts (flight/vaccine/address AI extraction)
OPENAI_API_KEY=

# ─── Resend (from https://resend.com/api-keys) ───
# 초대 이메일 자동 발송. 미설정 시 링크 복사만 동작 (발송 skip).
# INVITE_EMAIL_FROM: 검증된 도메인에서의 발신 주소. 미설정 시 onboarding@resend.dev (샌드박스)
RESEND_API_KEY=
INVITE_EMAIL_FROM=
